{
  "name": "france-essence",
  "version": "1.0.0",
  "description": "Projet de création d'une API backend permettant le suivi des prix des carburants en France (via l'Open Data du gouvernement) et la gestion de la consommation personnelle des utilisateurs.\r **Stack technique :** Node.js, Express, TypeScript, SQLite, ORM (Prisma ou TypeORM), Architecture MVC.",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "import:full": "ts-node src/scripts/runImport.ts",
    "import:cities": "ts-node src/scripts/runImportCities.ts",
    "import:fuel": "ts-node src/scripts/runImportFuel.ts",
    "import:file": "ts-node src/scripts/runImportFile.ts",
    "seed:test-user": "ts-node src/scripts/seedDefaultUser.ts",
    "test": "vitest run",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeoSLegrand/france-essence.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/LeoSLegrand/france-essence/issues"
  },
  "homepage": "https://github.com/LeoSLegrand/france-essence#readme",
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.5",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^4.5.4",
    "graphql": "^16.13.2",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  }
}
